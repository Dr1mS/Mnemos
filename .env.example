# Ollama
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=bge-m3
SALIENCE_MODEL=qwen3:4b
EXTRACTION_MODEL=qwen3:4b
# Profil GPU (3070 Ti) : EXTRACTION_MODEL=qwen3:8b possible -> tier MEDIUM active
LLM_THINK=false

# Storage
DATA_DIR=./data
EPISODIC_DB=./data/episodic.db
SEMANTIC_DB=./data/semantic.db
PROCEDURAL_DIR=./data/procedural

# Server
API_HOST=127.0.0.1
API_PORT=8765
LOG_LEVEL=INFO

# Memory dynamics
SALIENCE_THRESHOLD_CONSOLIDATE=0.6
SALIENCE_THRESHOLD_DECAY_FAST=0.2
DECAY_RATE_DAILY=0.05
CONSOLIDATION_DELAY_HOURS=1
EPISODIC_RETENTION_DAYS=90

# Consolidation worker
CONSOLIDATION_INTERVAL_MINUTES=60
CONSOLIDATION_BATCH_SIZE=20

# Concurrency (ModelManager)
LLM_TIER_SMALL_CONCURRENCY=4
LLM_TIER_MEDIUM_CONCURRENCY=1
